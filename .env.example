# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (if using PostgreSQL)
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=sisg_user
# DB_PASSWORD=your_secure_password_here
# DB_NAME=sisg_database

# Redis Configuration (if using caching)
# REDIS_URL=redis://redis:6379

# Authentication (if using Auth0 or similar)
# AUTH0_DOMAIN=your-domain.auth0.com
# AUTH0_CLIENT_ID=your_client_id
# AUTH0_CLIENT_SECRET=your_client_secret
# AUTH0_CALLBACK_URL=https://sentinelintegratedgroup.com/auth/callback

# API Configuration
# API_BASE_URL=https://sentinelintegratedgroup.com
# CORS_ORIGIN=https://sentinelintegratedgroup.com

# Optional: Monitoring & Logging
# SENTRY_DSN=
# LOG_LEVEL=info
