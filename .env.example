# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (DigitalOcean Managed PostgreSQL recommended)
# DB_PROVIDER=postgres
# DB_HOST=your-private-db-host.h.db.ondigitalocean.com
# DB_PORT=25060
# DB_USER=sisg_app
# DB_PASSWORD=your_secure_password_here
# DB_NAME=sisg_platform
# DB_SSL=true
# DATABASE_URL=postgresql://sisg_app:your_secure_password_here@your-private-db-host.h.db.ondigitalocean.com:25060/sisg_platform?sslmode=require
# DATABASE_PUBLIC_HOST=your-public-db-host.h.db.ondigitalocean.com
# DATABASE_CA_CERT_PATH=.digitalocean-managed-postgres-ca.pem

# Redis Configuration (if using caching)
# REDIS_URL=redis://redis:6379

# Local/bootstrap authentication
# AUTH_BOOTSTRAP_EMAIL=admin@sentinelintegratedgroup.com
# AUTH_BOOTSTRAP_PASSWORD=replace_with_a_real_password
# AUTH_BOOTSTRAP_DISPLAY_NAME=SISG Admin
# Legacy fallback only during migration:
# ADMIN_PIN=legacy_bootstrap_secret

# API Configuration
# API_BASE_URL=https://sentinelintegratedgroup.com
# CORS_ORIGIN=https://sentinelintegratedgroup.com

# Object Storage (DigitalOcean Spaces recommended)
# SPACES_REGION=sfo3
# SPACES_BUCKET=your-space-bucket-name
# SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
# SPACES_CDN_BASE_URL=https://your-space-bucket-name.sfo3.digitaloceanspaces.com
# SPACES_ACCESS_KEY_ID=your_spaces_access_key
# SPACES_SECRET_ACCESS_KEY=your_spaces_secret_key
# SPACES_FORCE_PATH_STYLE=false

# Optional: Monitoring & Logging
# SENTRY_DSN=
# LOG_LEVEL=info

# Slack Webhooks for Notifications
SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_FORMS_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ACTIVITY_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_DEPLOYMENTS_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
